  },
  "homepage": "https://github.com/ctonneslan/create-mcpx#readme",
  "bugs": {
    "url": "https://github.com/ctonneslan/create-mcpx/issues"
  },
  "dependencies": {
    "@clack/prompts": "^0.11.0",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "typescript": "^5.8.3",
